---
const res = await fetch(new URL("/api/public/software-list", Astro.request.url));
const data = res.ok ? await res.json() : { software: [] };
const list = Array.isArray(data.software) ? data.software : [];
const byDevice = list.reduce((acc: Record<string, any[]>, item) => {
  const dc = item.device_category || "other";
  if (!acc[dc]) acc[dc] = [];
  acc[dc].push(item);
  return acc;
}, {});
---
<html>
  <head>
    <meta charset="utf-8" />
    <title>软件列表</title>
  </head>
  <body>
    <h1>软件列表</h1>
    {list.length === 0 ? (
      <p>暂无软件数据</p>
    ) : (
      Object.entries(byDevice).map(([dc, items]) => (
        <section>
          <h2>{dc}</h2>
          <ul>
            {items.map((s) => (
              <li>
                <a href={`/software/${s.slug}`}>{s.name}</a>
              </li>
            ))}
          </ul>
        </section>
      ))
    )}

    <p><a href="/">返回首页</a></p>
  </body>
</html>
